{
  "name": "@focoris/auth-api-e2e",
  "version": "0.0.1",
  "private": true,
  "devDependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.0",
    "dotenv": "^16.6.1",
    "testcontainers": "^10.28.0"
  },
  "nx": {
    "implicitDependencies": [
      "@focoris/auth-api"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "auth-api-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@focoris/auth-api:db:generate",
          "@focoris/auth-api:build"
        ]
      },
      "e2e-ci": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec nx run @focoris/auth-api-e2e:e2e"
        }
      }
    }
  },
  "dependencies": {
    "@testcontainers/postgresql": "^11.12.0"
  }
}
