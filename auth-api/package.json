{
  "name": "@focoris/auth-api",
  "version": "0.0.1",
  "private": true,
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          "^build"
        ],
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "main": "auth-api/src/main.ts",
          "tsConfig": "auth-api/tsconfig.app.json",
          "outputPath": "auth-api/dist",
          "outputFileName": "src/main.js",
          "generatePackageJson": false
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/auth-api/dist/package.json",
          "{workspaceRoot}/auth-api/dist/pnpm-lock.yaml"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/auth-api/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "options": {
          "buildTarget": "@focoris/auth-api:build",
          "runBuildTargetDependencies": true
        },
        "configurations": {
          "development": {
            "buildTarget": "@focoris/auth-api:build"
          },
          "debug": {
            "buildTarget": "@focoris/auth-api:build",
            "inspect": "inspect",
            "host": "127.0.0.1",
            "port": 9230
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      },
      "db:generate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm -C auth-api exec prisma generate --schema prisma/schema.prisma"
        }
      },
      "db:migrate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm -C auth-api exec prisma migrate dev --schema prisma/schema.prisma"
        }
      },
      "db:seed": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm -C auth-api exec prisma db seed --schema prisma/schema.prisma"
        }
      }
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@focoris/auth-nest": "workspace:*",
    "@nestjs/testing": "^11.0.0",
    "prisma": "^6.16.2"
  }
}
